<article class="max-w-3xl mx-auto">
  {{#with post}}
  <header class="mb-8 pb-6 border-b border-gray-200">
    <h1 class="font-serif text-4xl font-bold text-gray-900 leading-tight mb-4">{{title}}</h1>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-500">
      <span class="font-medium text-gray-700">{{writer}}</span>
      <span>조회 {{hits}}</span>
      <span>{{dateString createdAt}}</span>
      <div class="ml-auto flex gap-2">
        <button onclick="modifyPost()"
          class="px-4 py-1.5 text-sm border border-gray-300 rounded-lg hover:border-green-500 hover:text-green-600 transition-colors">수정</button>
        <button onclick="deletePost()"
          class="px-4 py-1.5 text-sm border border-red-200 text-red-500 rounded-lg hover:bg-red-50 transition-colors">삭제</button>
      </div>
    </div>
  </header>

  <div class="text-gray-700 text-base leading-loose whitespace-pre-wrap mb-16">{{content}}</div>

  <!-- 댓글 섹션 -->
  <section aria-labelledby="comments-heading">
    <h3 id="comments-heading" class="font-serif text-xl font-bold text-gray-800 mb-6">
      댓글 {{lengthOfList comments}}개
    </h3>

    <form method="post" action="/write-comment" class="bg-gray-50 rounded-lg p-6 mb-8">
      <input type="hidden" name="id" value="{{_id}}"/>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <label class="flex flex-col gap-1">
          <span class="text-xs text-gray-500">이름</span>
          <input type="text" name="name" placeholder="이름"
            class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"/>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-xs text-gray-500">비밀번호</span>
          <input type="password" name="password" placeholder="비밀번호"
            class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"/>
        </label>
      </div>
      <label class="flex flex-col gap-1 mb-4">
        <span class="text-xs text-gray-500">댓글 내용</span>
        <textarea name="comment" rows="3" placeholder="댓글을 입력해주세요."
          class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none"></textarea>
      </label>
      <div class="flex justify-end">
        <button type="submit"
          class="bg-green-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition-colors">
          댓글 쓰기
        </button>
      </div>
    </form>

    <div class="space-y-5">
      {{#each comments}}
      <div class="border-b border-gray-100 pb-5">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-3">
            <span class="font-medium text-gray-800 text-sm">{{name}}</span>
            <span class="text-xs text-gray-400">{{dateString createdAt}}</span>
          </div>
          <button onclick="deleteComment('{{idx}}')"
            class="text-xs text-gray-400 hover:text-red-500 transition-colors">삭제</button>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-wrap">{{comment}}</p>
      </div>
      {{/each}}
    </div>
  </section>
  {{/with}}
</article>

<div class="mt-12 pt-6 border-t border-gray-200 max-w-3xl mx-auto">
  <a href="/" class="text-sm text-green-600 hover:text-green-700 transition-colors">← 목록으로</a>
</div>

<script>
  const postOption = {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
  };

  async function modifyPost() {
    const password = prompt('패스워드를 입력해주세요');
    if (!password) return;
    const result = await fetch('/check-password', {
      ...postOption,
      body: JSON.stringify({ id: "{{post._id}}", password })
    });
    const data = await result.json();
    if (data.isExist) {
      document.location = "/modify/{{post._id}}";
    } else {
      alert('패스워드가 올바르지 않습니다.');
    }
  }

  const deleteOption = {
    method: 'DELETE',
    headers: { 'Content-Type': 'application/json' },
  };

  async function deletePost() {
    const password = prompt('삭제하려면 패스워드를 입력해주세요');
    if (!password) return;
    const result = await fetch('/delete', {
      ...deleteOption,
      body: JSON.stringify({ id: "{{post._id}}", password })
    });
    const data = await result.json();
    if (!data.isSuccess) {
      alert('삭제에 실패했습니다. 패스워드를 확인해주세요.');
      return;
    }
    document.location = '/';
  }

  async function deleteComment(idx) {
    const password = prompt('삭제하려면 패스워드를 입력해주세요');
    if (!password) return;
    const result = await fetch('/delete-comment', {
      ...deleteOption,
      body: JSON.stringify({ id: "{{post._id}}", idx, password })
    });
    const data = await result.json();
    if (!data.isSuccess) {
      alert('삭제에 실패했습니다. 패스워드를 확인해주세요.');
      return;
    }
    alert('삭제 성공!');
    document.location.reload();
  }
</script>

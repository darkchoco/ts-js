<div class="max-w-2xl mx-auto">
  <h1 class="font-serif text-3xl font-bold text-gray-900 mb-8">
    {{#if (eq mode "create")}}새 글 작성{{else}}글 수정{{/if}}
  </h1>

  <form name="boardForm" method="post"
    {{#if (eq mode "create")}}action="/write"{{else}}action="/modify"{{/if}}
    class="space-y-5">

    {{#if (eq mode "modify")}}
      <input type="hidden" name="id" value="{{post._id}}"/>
    {{/if}}

    <label class="flex flex-col gap-1.5">
      <span class="text-sm font-medium text-gray-700">제목</span>
      <input type="text" name="title" placeholder="제목을 입력해주세요" value="{{post.title}}"
        class="border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500"/>
    </label>

    <label class="flex flex-col gap-1.5">
      <span class="text-sm font-medium text-gray-700">이름</span>
      <input type="text" name="writer" placeholder="이름을 입력해주세요" value="{{post.writer}}"
        class="border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500"/>
    </label>

    <label class="flex flex-col gap-1.5">
      <span class="text-sm font-medium text-gray-700">비밀번호</span>
      <input type="password" name="password" placeholder="비밀번호를 입력해주세요"
        class="border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500"/>
    </label>

    <label class="flex flex-col gap-1.5">
      <span class="text-sm font-medium text-gray-700">본문</span>
      <textarea name="content" placeholder="본문을 입력해주세요" rows="12"
        class="border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 resize-y leading-relaxed">{{post.content}}</textarea>
    </label>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit"
        class="bg-green-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-green-700 transition-colors">
        저장
      </button>
      <button type="button" onclick="location.href='/'"
        class="px-6 py-2.5 rounded-lg text-sm font-medium border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors">
        취소
      </button>
    </div>
  </form>
</div>

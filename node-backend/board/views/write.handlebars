<h1>[{{title}}] 글 작성</h1>
<div>
  <form name="boardForm" method="post" action="/write">
    <div>
      <label>제목</label>
      <label>
        <input type="text" name="title" placeholder="제목을 넣어주세요" value=""/>
      </label>
    </div>
    <div>
      <label>이름</label>
      <label>
        <input type="text" name="writer" placeholder="이름을 넣어주세요" value=""/>
      </label>
    </div>
    <div>
      <label>비밀번호</label>
      <label>
        <input type="password" name="password" placeholder="비밀번호를 넣어주세요"/>
      </label>
    </div>
    <div>
      <label>본문을 입력하세요</label><br/>
      <label>
        <textarea placeholder="본문" name="content" cols="50" rows="10"></textarea>
      </label>
      <br/>
      <!-- 버튼영역 -->
      <div>
        <button type="submit">저장</button>
        <button type="button" onclick="location.href='/'">취소</button>
      </div>
    </div>
  </form>
</div>

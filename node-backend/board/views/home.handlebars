<h1>{{title}}</h1> <!-- ❶ 타이틀 영역 -->

<!-- ❷ 검색어 영역  -->
<label for="search"></label>
<input type="text" name="search" id="search" value="{{search}}" size="50" placeholder="검색어를 입력하세요."/>
<button onclick="{
  const search = document.getElementById('search');
  if (search instanceof HTMLInputElement) {
    location.href = `/?search=${encodeURIComponent(search.value)}`;
  }
}">검색
</button>
<br/>

<!-- ❸ 글쓰기 페이지 이동 링크  -->
<a href="/write"> 글쓰기</a>
<br/>

<!-- ❹ 리스트 테이블  -->
<div>
  <table>
    <thead>
    <tr>
      <th style="width: 50%">제목</th>
      <th>작성자</th>
      <th>조회수</th>
      <th>등록일</th>
    </tr>
    </thead>
    <tbody>
    {{#each posts}}
      <tr>
        <td><a href="/detail/{{_id}}">{{title}}</a></td>
        <td>{{writer}}</td>
        <td>{{hits}}</td>
        <td>{{dateString createdAt}}</td>
      </tr>
    {{/each}}
    </tbody>
  </table>
</div>

<!-- ❺ 페이징 영역  -->
<div>
  {{#with paginator}}
    <a href="/?page=1&search={{@root.search}}">&lt;&lt;
    {{#if hasPrev}}
      <a href="/?page={{prevPage}}&search={{@root.search}}">&lt;
    {{else}}
      <a>&lt;</a>
    {{/if}}
    {{#each pageList}}
      {{#if (eq this @root.paginator.page)}}
        <a>{{.}}</a>
      {{else}}
        <a href="/?page={{.}}&search={{@root.search}}">{{.}}
      {{/if}}
    {{/each}}
    {{#if hasNext}}
      <a href="/?page={{nextPage}}&search={{@root.search}}">&gt;
    {{else}}
      <a>&gt;</a>
    {{/if}}
    <a href="/?page={{lastPage}}&search={{@root.search}}">&gt;&gt;
  {{/with}}
</div>

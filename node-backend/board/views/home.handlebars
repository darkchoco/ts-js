<!-- 검색 & 타이틀 -->
<div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4">
  <h1 class="font-serif text-3xl font-bold text-gray-900">{{title}}</h1>
  <div class="sm:ml-auto flex gap-2">
    <label for="search" class="sr-only">검색</label>
    <input type="text" id="search" name="search" value="{{search}}" placeholder="검색어를 입력하세요"
      class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 w-56"/>
    <button onclick="const s=document.getElementById('search'); if(s instanceof HTMLInputElement) location.href='/?search='+encodeURIComponent(s.value);"
      class="bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition-colors">
      검색
    </button>
  </div>
</div>

<!-- 글쓰기 버튼 -->
<div class="mb-6 flex justify-end">
  <a href="/write" class="bg-green-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition-colors">
    글쓰기
  </a>
</div>

<!-- 게시글 카드 목록 -->
<div class="space-y-3 mb-10">
  {{#each posts}}
  <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow">
    <a href="/detail/{{_id}}" class="block group">
      <h2 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-green-600 transition-colors">{{title}}</h2>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <span>{{writer}}</span>
        <span>조회 {{hits}}</span>
        <span>{{dateString createdAt}}</span>
      </div>
    </a>
  </div>
  {{/each}}
</div>

<!-- 페이지네이션 -->
<nav aria-label="페이지 탐색" class="flex items-center justify-center gap-1 flex-wrap">
  {{#with paginator}}
  <a href="/?page=1&search={{@root.search}}" aria-label="첫 페이지"
    class="px-3 py-1 rounded border border-gray-200 text-sm text-gray-500 hover:border-green-500 hover:text-green-600 transition-colors">&laquo;</a>
  {{#if hasPrev}}
    <a href="/?page={{prevPage}}&search={{@root.search}}" aria-label="이전 페이지"
      class="px-3 py-1 rounded border border-gray-200 text-sm text-gray-500 hover:border-green-500 hover:text-green-600 transition-colors">&lsaquo;</a>
  {{else}}
    <span class="px-3 py-1 rounded border border-gray-100 text-sm text-gray-300">&lsaquo;</span>
  {{/if}}
  {{#each pageList}}
    {{#if (eq this @root.paginator.page)}}
      <span class="px-3 py-1 rounded bg-green-600 text-white text-sm font-medium">{{.}}</span>
    {{else}}
      <a href="/?page={{.}}&search={{@root.search}}"
        class="px-3 py-1 rounded border border-gray-200 text-sm text-gray-600 hover:border-green-500 hover:text-green-600 transition-colors">{{.}}</a>
    {{/if}}
  {{/each}}
  {{#if hasNext}}
    <a href="/?page={{nextPage}}&search={{@root.search}}" aria-label="다음 페이지"
      class="px-3 py-1 rounded border border-gray-200 text-sm text-gray-500 hover:border-green-500 hover:text-green-600 transition-colors">&rsaquo;</a>
  {{else}}
    <span class="px-3 py-1 rounded border border-gray-100 text-sm text-gray-300">&rsaquo;</span>
  {{/if}}
  <a href="/?page={{lastPage}}&search={{@root.search}}" aria-label="마지막 페이지"
    class="px-3 py-1 rounded border border-gray-200 text-sm text-gray-500 hover:border-green-500 hover:text-green-600 transition-colors">&raquo;</a>
  {{/with}}
</nav>
